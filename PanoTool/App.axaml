<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Zenkei.App"
             xmlns:local="using:Zenkei"
             xmlns:vm="using:Zenkei.ViewModels"
             xmlns:views="using:Zenkei.Views"
             xmlns:dockFluent="using:Dock.Avalonia.Themes.Fluent"
             xmlns:dockControls="using:Dock.Avalonia.Controls"
>

    <Application.DataTemplates>
        <!-- Explicit templates for Dock tool/document ViewModels -->
        <DataTemplate DataType="vm:SceneListViewModel">
            <views:SceneListView/>
        </DataTemplate>
        <DataTemplate DataType="vm:PropertiesViewModel">
            <views:PropertiesView/>
        </DataTemplate>
        <DataTemplate DataType="vm:PanoramaEditorViewModel">
            <views:PanoramaEditorView/>
        </DataTemplate>
        <DataTemplate DataType="vm:OutputViewModel">
            <views:OutputView/>
        </DataTemplate>
        <!-- Fallback ViewLocator for any other ViewModelBase -->
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        
        <dockFluent:DockFluentTheme/>

        <!-- Two-part tab header for document tabs: bold internal ID + subdued title words.
             DocumentTabStrip.ItemTemplate provides the *content* of each tab item;
             the DocumentTabStripItem container still handles selection state, close button, etc.
             For non-PanoramaEditorViewModel items, TabSubTitle binding silently returns empty
             so only the Title TextBlock is visible. -->
        <Style Selector="dockControls|DocumentTabStrip">
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate x:DataType="vm:PanoramaEditorViewModel">
                        <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding TabSubTitle}"
                                       FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding TabSubTitle,
                                           Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                        </StackPanel>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Styles>
</Application>
