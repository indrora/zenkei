<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Zenkei.Controls"
             x:Class="Zenkei.Controls.YawPitchControl">

  <StackPanel Spacing="4">

    <!-- Equirectangular mini-map — drag to place the marker -->
    <controls:MarkerLocationControl x:Name="Map"/>

    <!-- Yaw / Pitch NUDs: shared two-column Grid so labels align and both NUDs
         get identical width filling the remaining space to the right. -->
    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,4,Auto">
      <TextBlock Grid.Row="0" Grid.Column="0"
                 Text="Yaw" VerticalAlignment="Center"
                 Opacity="0.65" FontSize="11" Margin="4,0,6,0"/>
      <NumericUpDown Grid.Row="0" Grid.Column="1" x:Name="YawNud"
                     Minimum="-180" Maximum="180" Increment="1"
                     FormatString="F0" AllowSpin="True"
                     HorizontalAlignment="Stretch"/>

      <TextBlock Grid.Row="2" Grid.Column="0"
                 Text="Pitch" VerticalAlignment="Center"
                 Opacity="0.65" FontSize="11" Margin="4,0,6,0"/>
      <NumericUpDown Grid.Row="2" Grid.Column="1" x:Name="PitchNud"
                     Minimum="0" Maximum="180" Increment="1"
                     FormatString="F0" AllowSpin="True"
                     HorizontalAlignment="Stretch"/>
    </Grid>

  </StackPanel>
</UserControl>
