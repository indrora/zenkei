<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zenkei.ViewModels"
             xmlns:pg="using:Avalonia.PropertyGrid.Controls"
             x:Class="Zenkei.Views.MarkerEditorView"
             x:DataType="vm:MarkerEditorViewModel">

  <DockPanel>

    <!-- Header: "no selection" hint + type switcher + coords -->
    <StackPanel DockPanel.Dock="Top" Margin="8,6,8,4" Spacing="4">

      <TextBlock Text="No marker selected" FontStyle="Italic" Opacity="0.6"
                 IsVisible="{Binding !HasMarker}"/>

      <StackPanel IsVisible="{Binding HasMarker}" Spacing="4">

        <TextBlock Text="Type" Classes="FormLabel"/>
        <ComboBox ItemsSource="{Binding MarkerTypes}"
                  SelectedItem="{Binding MarkerType}"
                  HorizontalAlignment="Stretch"/>

        <Grid ColumnDefinitions="*,6,*">
          <TextBlock Grid.Column="0" Text="Yaw (X)" Classes="FormLabel"/>
          <TextBlock Grid.Column="2" Text="Pitch (Y)" Classes="FormLabel"/>
        </Grid>
        <Grid ColumnDefinitions="*,6,*">
          <NumericUpDown Grid.Column="0" Value="{Binding CoordsX}"
                         Minimum="-3.1416" Maximum="3.1416"
                         FormatString="F4" Increment="0.01"/>
          <NumericUpDown Grid.Column="2" Value="{Binding CoordsY}"
                         Minimum="0" Maximum="3.1416"
                         FormatString="F4" Increment="0.01"/>
        </Grid>

        <Separator/>

      </StackPanel>
    </StackPanel>

    <!-- PropertyGrid for type-specific fields (Url, Text, TargetScene, Marker icon) -->
    <pg:PropertyGrid DataContext="{Binding CurrentMarker}"/>

  </DockPanel>
</UserControl>
