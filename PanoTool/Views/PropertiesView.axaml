<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zenkei.ViewModels"
             xmlns:controls="using:Zenkei.Controls"
             x:Class="Zenkei.Views.PropertiesView"
             x:DataType="vm:PropertiesViewModel"
             MinWidth="200">

  <Grid RowDefinitions="*,Auto">
    <!-- Shown when nothing is selected -->
    <TextBlock Grid.Row="0"
               IsVisible="{Binding Subject, Converter={x:Static ObjectConverters.IsNull}}"
               Text="No selection"
               FontStyle="Italic" Opacity="0.5"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

    <!-- PropertyGrid fills the panel; null DataContext renders as an empty grid -->
    <controls:ZenkeiPropertyGrid Grid.Row="0" DataContext="{Binding Subject}"/>

    <!-- Delete button — visible only when a real marker is selected -->
    <Button Grid.Row="1"
            Content="Delete Marker"
            Command="{Binding DeleteSelectedMarkerCommand}"
            IsVisible="{Binding CanDeleteMarker}"
            Margin="4"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"/>
  </Grid>

</UserControl>
