<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zenkei.ViewModels"
             xmlns:controls="using:Zenkei.Controls"
             x:Class="Zenkei.Views.PropertiesView"
             x:DataType="vm:PropertiesViewModel"
             MinWidth="200">

  <Grid>
    <!-- Shown when nothing is selected -->
    <TextBlock IsVisible="{Binding Subject, Converter={x:Static ObjectConverters.IsNull}}"
               Text="No selection"
               FontStyle="Italic" Opacity="0.5"
               HorizontalAlignment="Center" VerticalAlignment="Center"/>

    <!-- PropertyGrid fills the panel; null DataContext renders as an empty grid -->
    <controls:ZenkeiPropertyGrid DataContext="{Binding Subject}"/>
  </Grid>

</UserControl>
