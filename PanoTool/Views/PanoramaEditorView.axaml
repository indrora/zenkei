<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zenkei.ViewModels"
             xmlns:controls="using:Zenkei.Controls"
             x:Class="Zenkei.Views.PanoramaEditorView"
             x:DataType="vm:PanoramaEditorViewModel">

  <Grid>
    <controls:PanoramaCanvas
        x:Name="Canvas"
        Scene="{Binding Scene}"
        SelectedMarker="{Binding SelectedMarker}"
        />

    <!-- Zoom toolbar — top-right overlay, sits above the canvas -->
    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
            Background="#CC181828" CornerRadius="4" Margin="8"
            Padding="6,4">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <TextBlock Text="{Binding ZoomLabel}" Foreground="White"
                   VerticalAlignment="Center" FontSize="12"
                   MinWidth="46" TextAlignment="Right"/>
        <Button x:Name="ZoomInBtn"  Content="+" FontSize="13" Width="26" Padding="0"
                ToolTip.Tip="Zoom in (+10%)"/>
        <Button x:Name="ZoomOutBtn" Content="−" FontSize="13" Width="26" Padding="0"
                ToolTip.Tip="Zoom out (−10%)"/>
        <Separator Width="1" Margin="2,0" Background="#88FFFFFF"/>
        <Button x:Name="Zoom50Btn"  Content="50%"  Padding="5,1" FontSize="11"
                ToolTip.Tip="Zoom to 50% of native resolution"/>
        <Button x:Name="Zoom100Btn" Content="100%" Padding="5,1" FontSize="11"
                ToolTip.Tip="Zoom to native pixel resolution"/>
        <Button Content="Fit" Command="{Binding ResetZoomCommand}" Padding="5,1" FontSize="11"
                ToolTip.Tip="Fit image to window"/>
      </StackPanel>
    </Border>

    <!-- Marker actions — bottom-left overlay -->
    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
            Background="#CC181828" CornerRadius="4" Margin="8"
            Padding="6,4">
      <StackPanel Orientation="Horizontal" Spacing="4">
        <TextBlock Text="Add:" Foreground="White" VerticalAlignment="Center"
                   FontSize="11" Opacity="0.7"/>
        <Button Command="{Binding AddInfoMarkerCommand}"  Content="Info"
                Padding="5,1" FontSize="11" ToolTip.Tip="Add Info marker at image centre"/>
        <Button Command="{Binding AddSceneMarkerCommand}" Content="Scene"
                Padding="5,1" FontSize="11" ToolTip.Tip="Add Scene Link marker at image centre"/>
        <Button Command="{Binding AddLinkMarkerCommand}"  Content="Link"
                Padding="5,1" FontSize="11" ToolTip.Tip="Add URL Link marker at image centre"/>
        <Separator Width="1" Margin="2,0" Background="#88FFFFFF"
                   IsVisible="{Binding CanDeleteMarker}"/>
        <Button Command="{Binding DeleteSelectedMarkerCommand}" Content="Delete"
                Padding="5,1" FontSize="11" ToolTip.Tip="Delete the selected marker"
                IsVisible="{Binding CanDeleteMarker}"/>
      </StackPanel>
    </Border>

  </Grid>
</UserControl>
