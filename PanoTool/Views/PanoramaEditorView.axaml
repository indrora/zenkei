<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PanoTool.ViewModels"
             xmlns:controls="using:PanoTool.Controls"
             x:Class="PanoTool.Views.PanoramaEditorView"
             x:DataType="vm:PanoramaEditorViewModel">

  <Grid>
    <controls:PanoramaCanvas
        x:Name="Canvas"
        Scene="{Binding Scene}"
        SelectedMarker="{Binding SelectedMarker}"
        />

    <!-- Context menu for adding markers -->
    <Grid.ContextMenu>
      <ContextMenu x:Name="CanvasContextMenu">
        <MenuItem Header="Add Info Marker"    Tag="info"/>
        <MenuItem Header="Add Link Marker"    Tag="link"/>
        <MenuItem Header="Add Scene Link"     Tag="scene"/>
      </ContextMenu>
    </Grid.ContextMenu>
  </Grid>
</UserControl>
