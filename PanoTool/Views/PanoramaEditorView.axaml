<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zenkei.ViewModels"
             xmlns:controls="using:Zenkei.Controls"
             x:Class="Zenkei.Views.PanoramaEditorView"
             x:DataType="vm:PanoramaEditorViewModel">

  <Grid>
    <controls:PanoramaCanvas
        x:Name="Canvas"
        Scene="{Binding Scene}"
        SelectedMarker="{Binding SelectedMarker}"
        />

    <!-- Zoom HUD — top-right overlay, sits above the canvas -->
    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
            Background="#CC181828" CornerRadius="4" Margin="8"
            Padding="6,3">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <TextBlock Text="{Binding ZoomLabel}" Foreground="White"
                   VerticalAlignment="Center" FontSize="12"/>
        <Button Content="Fit" Command="{Binding ResetZoomCommand}"
                Padding="4,1" FontSize="11"
                ToolTip.Tip="Reset zoom to fit window (also: double-click canvas edge)"/>
      </StackPanel>
    </Border>

    <!-- Context menu for adding markers -->
    <Grid.ContextMenu>
      <ContextMenu x:Name="CanvasContextMenu">
        <MenuItem Header="Add Info Marker"    Tag="info"/>
        <MenuItem Header="Add Link Marker"    Tag="link"/>
        <MenuItem Header="Add Scene Link"     Tag="scene"/>
      </ContextMenu>
    </Grid.ContextMenu>
  </Grid>
</UserControl>
