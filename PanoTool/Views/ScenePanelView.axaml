<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zenkei.ViewModels"
             x:Class="Zenkei.Views.SceneListView"
             x:DataType="vm:SceneListViewModel"
             MinWidth="180">

  <DockPanel>

    <!-- Header -->
    <Border DockPanel.Dock="Top"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
            BorderThickness="0,0,0,1" Padding="6,4">
      <DockPanel>
        <TextBlock Text="Explorer" FontWeight="SemiBold" VerticalAlignment="Center"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
          <Button Command="{Binding AddImageCommand}"
                  ToolTip.Tip="Add image as new scene"
                  Padding="6,2">+</Button>
          <Button Command="{Binding RemoveSceneCommand}"
                  ToolTip.Tip="Remove selected scene"
                  Padding="6,2">−</Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- VS-style project explorer tree.
         TourRootNode → ScenesFolderNode → SceneItemNode → [ImageFileNode, MarkerItemNode...] -->
    <TreeView ItemsSource="{Binding TreeNodes}"
              SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}">
      <TreeView.DataTemplates>

        <!-- ── Tour root ── -->
        <TreeDataTemplate x:DataType="vm:TourRootNode" ItemsSource="{Binding Children}">
          <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
            <TextBlock Text="{Binding Icon}"
                       Foreground="{DynamicResource SystemAccentColorBrush}"
                       FontSize="10" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" VerticalAlignment="Center"/>
          </StackPanel>
        </TreeDataTemplate>

        <!-- ── Scenes folder ── -->
        <TreeDataTemplate x:DataType="vm:ScenesFolderNode" ItemsSource="{Binding Children}">
          <TextBlock Text="{Binding Label}" Opacity="0.8" VerticalAlignment="Center"/>
        </TreeDataTemplate>

        <!-- ── Scene item (expandable) ── -->
        <TreeDataTemplate x:DataType="vm:SceneItemNode" ItemsSource="{Binding Children}">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <!-- Coloured square mimics VS file-type icon -->
            <Border Width="9" Height="9" Background="#4A9EFF"
                    CornerRadius="2" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Label}"
                       FontFamily="Cascadia Code,Consolas,Courier New,monospace"
                       FontSize="12" VerticalAlignment="Center"/>
          </StackPanel>
        </TreeDataTemplate>

        <!-- ── Initial POV (leaf) ── -->
        <DataTemplate x:DataType="vm:InitialPovNode">
          <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
            <TextBlock Text="{Binding Icon}"
                       Foreground="{DynamicResource SystemAccentColorBrush}"
                       FontSize="11" VerticalAlignment="Center" Opacity="0.8"/>
            <TextBlock Text="{Binding Label}"
                       FontSize="11" Opacity="0.75" VerticalAlignment="Center"/>
          </StackPanel>
        </DataTemplate>

        <!-- ── Image file (leaf) ── -->
        <DataTemplate x:DataType="vm:ImageFileNode">
          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <Border Width="8" Height="8"
                    BorderBrush="#666666" BorderThickness="1"
                    Background="Transparent" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Label}"
                       FontSize="11" Opacity="0.65" FontStyle="Italic"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </DataTemplate>

        <!-- ── Marker (leaf) ── -->
        <DataTemplate x:DataType="vm:MarkerItemNode">
          <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
            <TextBlock Text="{Binding Icon}"
                       Foreground="{Binding IconBrush}"
                       FontSize="11" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Label}" FontSize="11" VerticalAlignment="Center"/>
          </StackPanel>
        </DataTemplate>

      </TreeView.DataTemplates>
    </TreeView>

  </DockPanel>
</UserControl>
