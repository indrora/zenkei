<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Zenkei.ViewModels"
             xmlns:models="using:Zenkei.Models"
             xmlns:pg="using:Avalonia.PropertyGrid.Controls"
             x:Class="Zenkei.Views.ScenePanelView"
             x:DataType="vm:ScenePanelViewModel">

  <Grid RowDefinitions="Auto,*,Auto,*">

    <!-- Row 0: Header -->
    <Border Grid.Row="0"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
            BorderThickness="0,0,0,1" Padding="6,4">
      <DockPanel>
        <TextBlock Text="Scenes" FontWeight="SemiBold" VerticalAlignment="Center"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4">
          <Button Command="{Binding AddImageCommand}"
                  ToolTip.Tip="Add image as new scene"
                  Padding="6,2">+</Button>
          <Button Command="{Binding RemoveSceneCommand}"
                  ToolTip.Tip="Remove selected scene"
                  Padding="6,2">−</Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- Row 1: Scene list -->
    <ListBox Grid.Row="1"
             ItemsSource="{Binding Scenes}"
             SelectedItem="{Binding SelectedScene}">
      <ListBox.ItemTemplate>
        <DataTemplate DataType="models:Scene">
          <TextBlock Text="{Binding Title}" Padding="4,2"/>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>

    <!-- Row 2: Initial view (array — not shown in PropertyGrid) -->
    <StackPanel Grid.Row="2"
                Margin="8,6,8,4" Spacing="4"
                IsVisible="{Binding HasSelectedScene}">
      <Separator/>
      <TextBlock Text="Initial view (yaw / pitch rad)" Classes="FormLabel"/>
      <Grid ColumnDefinitions="*,6,*">
        <NumericUpDown Grid.Column="0" Value="{Binding SceneInitialX}"
                       Minimum="-3.1416" Maximum="3.1416"
                       FormatString="F4" Increment="0.05"
                       ToolTip.Tip="Yaw (-π … π)"/>
        <NumericUpDown Grid.Column="2" Value="{Binding SceneInitialY}"
                       Minimum="0" Maximum="3.1416"
                       FormatString="F4" Increment="0.05"
                       ToolTip.Tip="Pitch (0=top, π=bottom)"/>
      </Grid>
    </StackPanel>

    <!-- Row 3: PropertyGrid for Title, Description, Image, HFov -->
    <pg:PropertyGrid Grid.Row="3"
                     DataContext="{Binding SelectedScene}"/>

  </Grid>
</UserControl>
